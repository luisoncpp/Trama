{
  "name": "trama",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/electron/main.js",
    "dev:desktop": "concurrently --names \"renderer,electron\" --success \"command-electron\" --kill-others \"npm run dev:renderer\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:smoke": "npm run build && vitest run tests/electron-smoke.test.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@toast-ui/editor": "^3.2.2",
    "@types/turndown": "^5.0.6",
    "chokidar": "^5.0.0",
    "marked": "^17.0.5",
    "preact": "^10.29.0",
    "quill": "^2.0.3",
    "turndown": "^7.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "eslint": "^9.38.0",
    "@typescript-eslint/parser": "^8.46.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6"
  }
}
